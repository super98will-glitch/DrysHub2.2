-- ================= ESP DRAWING SYSTEM =================
local ESP_Settings = { Enabled = false, Boxes = true, Names = true, Health = true, Distance = true }
local espObjects = {}

local function createEspDrawing(plr)
    local draw = {
        Box = Drawing.new("Square"), Outline = Drawing.new("Square"),
        Name = Drawing.new("Text"), HealthBar = Drawing.new("Square"),
        HealthBG = Drawing.new("Square"), Dist = Drawing.new("Text")
    }
    draw.Box.Thickness = 1.5
    draw.Box.Color = Theme.Main
    draw.Outline.Thickness = 3
    draw.Outline.Color = Color3.new(0,0,0)
    draw.Name.Size = 14
    draw.Name.Center = true
    draw.Name.Outline = true
    draw.Dist.Size = 12
    draw.Dist.Center = true
    draw.Dist.Outline = true
    draw.HealthBar.Filled = true
    draw.HealthBG.Filled = true
    draw.HealthBG.Color = Color3.new(0,0,0)
    espObjects[plr] = draw
end

RunService.RenderStepped:Connect(function()
    if not ESP_Settings.Enabled then
        for _, d in pairs(espObjects) do for _, v in pairs(d) do v.Visible = false end end
        return
    end
    for plr, draw in pairs(espObjects) do
        local char = plr.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChild("Humanoid")
        if hrp and hum and hum.Health > 0 then
            local pos, onScreen = camera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local sizeY = (camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 3.5, 0)).Y - camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, -4.5, 0)).Y)
                local sizeX = sizeY * 0.6
                draw.Box.Visible = ESP_Settings.Boxes
                draw.Box.Size = Vector2.new(sizeX, sizeY)
                draw.Box.Position = Vector2.new(pos.X - sizeX/2, pos.Y - sizeY/2)
                draw.Outline.Visible = ESP_Settings.Boxes
                draw.Outline.Size = draw.Box.Size
                draw.Outline.Position = draw.Box.Position
                draw.Name.Visible = ESP_Settings.Names
                draw.Name.Text = plr.Name
                draw.Name.Position = Vector2.new(pos.X, pos.Y - sizeY/2 - 18)
                draw.Dist.Visible = ESP_Settings.Distance
                draw.Dist.Text = math.floor((hrp.Position - player.Character.HumanoidRootPart.Position).Magnitude) .. "m"
                draw.Dist.Position = Vector2.new(pos.X, pos.Y + sizeY/2 + 5)
                draw.HealthBG.Visible = ESP_Settings.Health
                draw.HealthBG.Size = Vector2.new(3, sizeY)
                draw.HealthBG.Position = Vector2.new(pos.X - sizeX/2 - 6, pos.Y - sizeY/2)
                draw.HealthBar.Visible = ESP_Settings.Health
                draw.HealthBar.Size = Vector2.new(3, sizeY * (hum.Health/hum.MaxHealth))
                draw.HealthBar.Position = Vector2.new(pos.X - sizeX/2 - 6, pos.Y + sizeY/2 - draw.HealthBar.Size.Y)
                draw.HealthBar.Color = Color3.fromHSV(hum.Health/hum.MaxHealth * 0.3, 1, 1)
            else for _, v in pairs(draw) do v.Visible = false end end
        else for _, v in pairs(draw) do v.Visible = false end end
    end
end)

