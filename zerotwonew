-- ================= PERFORMANCE: ULTRA FPS BOOST =================
local function ApplyFPSBoost()
    Lighting.GlobalShadows = false
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("PostEffect") or effect:IsA("Bloom") or effect:IsA("Blur") then effect.Enabled = false end
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.CastShadow = false
        end
        if obj:IsA("ParticleEmitter") or obj:IsA("Trail") then obj.Enabled = false end
        local name = obj.Name:lower()
        if name:find("tree") or name:find("rock") or name:find("bush") or name:find("grass") then obj:Destroy() end
    end
end

