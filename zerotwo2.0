-- Configurações de Ativação
_G.AutoFarm = false
_G.AutoClick = false
_G.ESP_Enabled = false

-- Temas (Textos Brancos e Maiores)
local Theme = {
    Main = Color3.fromRGB(255, 107, 157),
    Dark = Color3.fromRGB(15, 15, 15),
    Secondary = Color3.fromRGB(25, 25, 30),
    White = Color3.fromRGB(255, 255, 255)
}

-- ===== LÓGICA DE AUTO CLICK E AUTO FARM =====
-- Auto Click Real
spawn(function()
    while task.wait() do
        if _G.AutoClick then
            VirtualUser:CaptureController()
            VirtualUser:Button1Down(Vector2.new(1280, 672))
        end
    end
end)

-- Auto Farm (Kill Aura / Magnet Base)
spawn(function()
    while task.wait() do
        if _G.AutoFarm then
            pcall(function()
                for _, v in pairs(workspace.Enemies:GetChildren()) do
                    if v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v:FindFirstChild("HumanoidRootPart") then
                        -- Traz o inimigo para sua frente (Magnet)
                        v.HumanoidRootPart.CFrame = player.Character.HumanoidRootPart.CFrame * CFrame.new(0, 0, -5)
                        v.HumanoidRootPart.CanCollide = false
                        v.Humanoid.WalkSpeed = 0
                    end
                end
            end)
        end
    end
end)

-- ===== INTERFACE (GUI) =====
if player.PlayerGui:FindFirstChild("ZeroTwoHub") then player.PlayerGui.ZeroTwoHub:Destroy() end
local gui = Instance.new("ScreenGui")
gui.Name = "ZeroTwoHub"
gui.Parent = player.PlayerGui

local function addDecor(obj, radius, stroke)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius)
    corner.Parent = obj
    if stroke then
        local st = Instance.new("UIStroke")
        st.Color = stroke
        st.Thickness = 2
        st.Parent = obj
    end
end

-- Função Arrastar
local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true dragStart = input.Position startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    frame.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
end

