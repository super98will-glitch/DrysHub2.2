-- ESP (Mantido conforme original)
local espEnabled = false
local espBox = true
local espName = true
local espHealth = true
local espObjects = {}
local camera = workspace.CurrentCamera

local function createESP(player)
	local drawingTable = {
		Box = Drawing.new("Square"),
		Name = Drawing.new("Text"),
		HealthBar = Drawing.new("Square"),
		HealthText = Drawing.new("Text")
	}
	drawingTable.Box.Thickness = 1
	drawingTable.Box.Filled = false
	drawingTable.Box.Color = Color3.new(1, 1, 1)
	drawingTable.Name.Size = 13
	drawingTable.Name.Center = true
	drawingTable.Name.Outline = true
	drawingTable.Name.Color = Color3.new(1, 1, 1)
	drawingTable.HealthBar.Thickness = 0
	drawingTable.HealthBar.Filled = true
	drawingTable.HealthBar.Color = Color3.new(0, 1, 0)
	drawingTable.HealthText.Size = 12
	drawingTable.HealthText.Center = true
	drawingTable.HealthText.Outline = true
	drawingTable.HealthText.Color = Color3.new(1, 1, 1)
	espObjects[player] = drawingTable
end

local function updateESPForPlayer(plr)
	if not espEnabled then return end
	local character = plr.Character
	if not character then
		if espObjects[plr] then for _, obj in pairs(espObjects[plr]) do obj.Visible = false end end
		return
	end
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
	if not humanoid or not rootPart then return end
	local head = character:FindFirstChild("Head")
	local headPos = head and head.Position or rootPart.Position + Vector3.new(0, 2, 0)
	local footPos = rootPart.Position - Vector3.new(0, 2, 0)
	local headScreen, onScreenHead = camera:WorldToViewportPoint(headPos)
	local footScreen, onScreenFoot = camera:WorldToViewportPoint(footPos)
	if not (onScreenHead or onScreenFoot) then
		if espObjects[plr] then for _, obj in pairs(espObjects[plr]) do obj.Visible = false end end
		return
	end
	local height = footScreen.Y - headScreen.Y
	local width = height * 0.6
	local boxColor = (plr.TeamColor == player.TeamColor) and Theme.Accent or Theme.Accent2
	local esp = espObjects[plr]
	if not esp then return end
	if espBox then
		esp.Box.Visible = true
		esp.Box.Color = boxColor
		esp.Box.Position = Vector2.new(headScreen.X - width/2, headScreen.Y)
		esp.Box.Size = Vector2.new(width, height)
	else esp.Box.Visible = false end
	if espName then
		esp.Name.Visible = true
		esp.Name.Text = plr.Name
		esp.Name.Position = Vector2.new(headScreen.X, headScreen.Y - 16)
		esp.Name.Color = boxColor
	else esp.Name.Visible = false end
	if espHealth and humanoid then
		local hp = humanoid.Health / humanoid.MaxHealth
		esp.HealthBar.Visible = true
		esp.HealthBar.Color = Color3.new(1-hp, hp, 0)
		esp.HealthBar.Position = Vector2.new(headScreen.X - width/2, headScreen.Y - 6)
		esp.HealthBar.Size = Vector2.new(width * hp, 4)
	else esp.HealthBar.Visible = false end
end

local espConnection
local function startESP()
	if espConnection then espConnection:Disconnect() end
	espConnection = RunService.RenderStepped:Connect(function()
		for _, plr in ipairs(Players:GetPlayers()) do
			if plr ~= player then updateESPForPlayer(plr) end
		end
	end)
end

for _, plr in ipairs(Players:GetPlayers()) do if plr ~= player then createESP(plr) end end
Players.PlayerAdded:Connect(function(plr) if plr ~= player then createESP(plr) end end)

