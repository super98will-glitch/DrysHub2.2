local function createToggle(text, varName, parent)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1, -10, 0, 40)
	btn.BackgroundColor3 = Theme.Button
	btn.Text = text .. ": OFF"
	btn.Font = Enum.Font.Gotham
	btn.TextColor3 = Theme.Text
	btn.ZIndex = 3
	btn.Parent = parent
	applyDesign(btn, 8, Theme.Accent2)
	btn.MouseButton1Click:Connect(function()
		getfenv()[varName] = not getfenv()[varName]
		btn.Text = text .. ": " .. (getfenv()[varName] and "ON" or "OFF")
		btn.BackgroundColor3 = getfenv()[varName] and Color3.fromRGB(80, 50, 50) or Theme.Button
	end)
end

